# Supabase — required
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Anthropic — optional. When set, /api/analyze calls claude-sonnet-4-6 with
# athlete profile + last 5 logs as context. Without it, the analyzer falls
# back to a deterministic heuristic mock that consumes the same inputs.
# ANTHROPIC_API_KEY=
